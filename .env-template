NANOGPT_API_KEY=""
NANOGPT_BASE_URL="https://nano-gpt.com/api/v1"
# Fast drafting model (same throughput route AutoCVApply uses for OCR/draft speed).
NANOGPT_MODEL="deepseek/deepseek-v4-flash:throughput"
# Vision scoring for Discover autoswipe (match AutoCVApply vision route).
NANOGPT_VISION_MODEL="openai/gpt-4.1-mini:speed"

# Discover autoswipe defaults (overridden by setup_autoswipe.py → SQLite + JSON).
AUTOSWIPE_PRESET="default"
PROFILE_MIN_ATTRACTIVENESS="6"
PROFILE_MIN_SLIMNESS="5"
PROFILE_MIN_QUIRKINESS="0"
PROFILE_MIN_ETHNICITY_FIT="0"
PROFILE_MIN_COMPOSITE="6"
PROFILE_WEIGHT_ATTRACTIVENESS="0.45"
PROFILE_WEIGHT_SLIMNESS="0.25"
PROFILE_WEIGHT_QUIRKINESS="0.15"
PROFILE_WEIGHT_ETHNICITY_FIT="0.15"
PROFILE_IMAGE_COUNT="3"
AUTOSWIPE_MAX_SWIPES="15"
AUTOSWIPE_PASTE_COMMENT="true"
# Soft vision preference, e.g. East/Southeast Asian. Empty = unused.
# Hinge Discover ethnicity filters (if available in your region) should be set
# manually once in the app; ADB cannot reliably drive that Filters UI.
AUTOSWIPE_ETHNICITY_PREFERENCE=""

YOUR_TURN_MAX_CHATS="13"
YOUR_TURN_PASTE_DRAFTS="true"
STYLE_INIT_MAX_CHATS="25"
# ADB server host. Local USB: 127.0.0.1. From Docker: host.docker.internal
ADB_SERVER_HOST="127.0.0.1"
# Optional phone LAN IP after `adb tcpip 5555` (wireless). Leave empty for USB.
DEVICE_IP=""
# Optional override (Docker compose sets /data/pitchperfect.db).
# SQLITE_PATH="app/data/pitchperfect.db"
